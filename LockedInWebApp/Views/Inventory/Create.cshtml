@model LockedInWebApp.Models.Item

@{
    ViewData["Title"] = "Add Item";
}

<h2>Add New Item</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Item Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Blue Denim Jacket" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description (optional)</label>
        <input asp-for="Description" class="form-control" placeholder="e.g. Size M, vintage style" />
    </div>

    <div class="mb-3">
        <label asp-for="PurchasePrice" class="form-label">Purchase Price ($)</label>
        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
        <span asp-validation-for="PurchasePrice" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Add Item</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
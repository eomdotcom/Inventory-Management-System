@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>
<p class="text-muted">Your inventory summary</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Items</h5>
                <h2>@ViewBag.TotalItems</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Sold</h5>
                <h2>@ViewBag.SoldItems</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Available</h5>
                <h2>@ViewBag.AvailableItems</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 mb-3">
        <div class="card border-danger">
            <div class="card-body">
                <h5 class="card-title text-danger">Total Spent</h5>
                <h2>@ViewBag.TotalSpent.ToString("F2")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-success">
            <div class="card-body">
                <h5 class="card-title text-success">Total Earned</h5>
                <h2>@ViewBag.TotalEarned.ToString("F2")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card @(ViewBag.TotalProfit >= 0 ? "bg-success" : "bg-danger") text-white">
            <div class="card-body">
                <h5 class="card-title">Total Profit</h5>
                <h2>@ViewBag.TotalProfit.ToString("F2")</h2>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-primary">View Inventory</a>
    <a asp-action="Create" class="btn btn-success">+ Add Item</a>
</div>